@{
    ViewData["Title"] = "clipin.";
}

<div class="clipin-hero">
    <div class="selection-wrapper">
        <span class="corner corner-tl"></span>
        <span class="corner corner-tr"></span>
        <span class="corner corner-bl"></span>
        <span class="corner corner-br"></span>

        <div class="clipin-hero-inner">
            <div class="hero-eyebrow">
                <span class="rec-dot"></span>
                @Localizer["Clipin_Hero_Eyebrow"]
            </div>
            <h1>clipin<span class="clipin-dot">.</span></h1>
            <p class="clipin-hero-sub">@Localizer["Clipin_Hero_Line2"]</p>
            <div class="clipin-hero-actions">
                <a href="https://github.com/paiineli/clipin/releases" target="_blank" rel="noopener noreferrer" class="btn btn-solid">
                    <i class="bi bi-download me-1" aria-hidden="true"></i>@Localizer["Clipin_Download_CTA"]
                </a>
                <a href="https://github.com/paiineli/clipin" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
                    <i class="bi bi-github me-1" aria-hidden="true"></i>@Localizer["Clipin_GitHub_CTA"]
                </a>
            </div>
            <div class="feature-chips">
                <span>@Localizer["Clipin_Chip1"]</span>
                <span class="chip-sep">·</span>
                <span>@Localizer["Clipin_Chip2"]</span>
                <span class="chip-sep">·</span>
                <span>@Localizer["Clipin_Chip4"]</span>
            </div>
        </div>
    </div>
</div>
