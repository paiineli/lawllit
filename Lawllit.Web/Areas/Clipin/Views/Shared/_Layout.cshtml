@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isPtBr = culture == "pt-BR";
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "clipin.")</title>
    <meta name="description" content="@Localizer["Clipin_Hero_Sub"]" />
    <link rel="canonical" href="https://lawllit.com@(Context.Request.Path)" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23000'/><circle cx='16' cy='16' r='8' fill='%23ef4444'/></svg>" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/clipin/css/app.css" asp-append-version="true" />
</head>
<body>

    <nav id="clipin-nav">
        <div class="container-lg nav-inner">
            <a class="clipin-brand" asp-area="Clipin" asp-controller="Home" asp-action="Index">
                <span>clipin<span class="clipin-brand-dot">.</span></span>
                <span class="rec-badge">
                    <span class="rec-dot"></span>                    
                </span>
            </a>
            <div class="nav-right">
                <form asp-area="" asp-controller="Home" asp-action="SetLanguage" method="post" class="lang mb-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                    <button type="submit" name="language" value="pt-BR" class="@(isPtBr ? "on" : "")">PT</button>
                    <span class="lang-sep">/</span>
                    <button type="submit" name="language" value="en-US" class="@(!isPtBr ? "on" : "")">EN</button>
                </form>
                <a class="nav-back" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> lawllit.
                </a>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container-lg footer-shell">
            <span>© @DateTime.Now.Year <span class="footer-brand">lawllit<span class="brand-dot">.</span></span></span>
            <div class="footer-links">
                <a href="https://linkedin.com/company/lawllit" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
