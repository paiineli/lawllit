@model ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
    var summaryClass = ViewData.ModelState.IsValid ? "d-none" : "";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="text-center mb-4">
            <h1 class="fs-4 fw-bold mb-1">lawllit<span class="brand-dot">.</span><span class="brand-finance">finance</span></h1>
            <p class="text-secondary small mb-0">@Localizer["Auth_PersonalFinance"]</p>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-4">@Localizer["Reset_Title"]</h5>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 @summaryClass"></div>

                <form asp-action="ResetPassword" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="Token" type="hidden">

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small">@Localizer["Reset_Title"] <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" class="form-control" id="resetPwd"
                                   placeholder="@Localizer["Reset_PasswordPlaceholder"]" autocomplete="new-password">
                            <button class="btn btn-outline-secondary" type="button" data-toggle-pwd="resetPwd"
                                    tabindex="-1" aria-label="@Localizer["Aria_ShowPassword"]">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label small">@Localizer["Prof_Security_ConfirmNewPwd"] <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" type="password" class="form-control" id="resetPwdConfirm"
                                   placeholder="@Localizer["Reset_ConfirmPlaceholder"]" autocomplete="new-password">
                            <button class="btn btn-outline-secondary" type="button" data-toggle-pwd="resetPwdConfirm"
                                    tabindex="-1" aria-label="@Localizer["Aria_ShowPassword"]">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">@Localizer["Reset_Submit"]</button>
                </form>

            </div>
        </div>

    </div>
</div>
