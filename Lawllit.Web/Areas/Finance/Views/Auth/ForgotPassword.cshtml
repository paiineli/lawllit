@model ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    var summaryClass = ViewData.ModelState.IsValid ? "d-none" : "";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="text-center mb-4">
            <h1 class="fs-4 fw-bold mb-1">lawllit<span class="brand-dot">.</span><span class="brand-finance">finance</span></h1>
            <p class="text-secondary small mb-0">@Localizer["Auth_PersonalFinance"]</p>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-1">@Localizer["Forgot_Title"]</h5>
                <p class="text-secondary small mb-4">@Localizer["Forgot_Subtitle"]</p>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 @summaryClass"></div>

                <form asp-action="ForgotPassword" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label small">@Localizer["Lbl_Email"]</label>
                        <input asp-for="Email" class="form-control" placeholder="@Localizer["Placeholder_Email"]" autocomplete="email">
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">@Localizer["Forgot_Submit"]</button>
                </form>

                <p class="text-center text-secondary small mt-3 mb-0">
                    @Localizer["Forgot_Remember"]
                    <a asp-action="Login" class="text-green">@Localizer["Login_Title"]</a>
                </p>

            </div>
        </div>

    </div>
</div>
