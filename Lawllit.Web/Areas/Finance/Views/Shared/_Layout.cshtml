@{
    var theme = User.FindFirst("theme")?.Value ?? "dark";
    var fontSize = User.FindFirst("font_size")?.Value ?? "normal";
    var currentLanguage = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var bsTheme = theme == "high-contrast" ? "dark" : theme;
    var titlePart = ViewData["Title"] as string;
    var pageTitle = !string.IsNullOrEmpty(titlePart)
        ? titlePart + " · lawllit.finance"
        : "lawllit.finance · Controle financeiro pessoal";
    var pageDescription = ViewData["Description"] as string
        ?? "Controle suas receitas e despesas, acompanhe cotações em tempo real e mantenha suas finanças organizadas.";
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
}
<!DOCTYPE html>
<html lang="@currentLanguage" data-bs-theme="@bsTheme" data-theme="@theme" @(fontSize != "normal" ? $"data-font-size=\"{fontSize}\"" : "")>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>lawllit.finance</title>
    <meta name="description" content="@pageDescription">
    <meta name="robots" content="@(User.Identity?.IsAuthenticated == true ? "noindex,nofollow" : "index,follow")">
    <link rel="canonical" href="@canonicalUrl">

    <meta property="og:type" content="website">
    <meta property="og:title" content="@pageTitle">
    <meta property="og:description" content="@pageDescription">
    <meta property="og:url" content="@canonicalUrl">
    <meta property="og:locale" content="pt_BR">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/finance/css/app.css" rel="stylesheet" asp-append-version="true">
    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23000'/><text x='50%25' y='55%25' dominant-baseline='middle' text-anchor='middle' fill='%234ade80' font-family='monospace' font-weight='bold' font-size='18'>L.</text></svg>">
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg sticky-top border-bottom" id="main-nav">
            <div class="container-lg">
                <a class="navbar-brand" asp-area="Finance" asp-controller="Dashboard" asp-action="Index">
                    lawllit<span class="brand-dot">.</span><span class="brand-finance">finance</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav me-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                               asp-area="Finance" asp-controller="Dashboard" asp-action="Index">@Localizer["Nav_Dashboard"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")"
                               asp-area="Finance" asp-controller="Transaction" asp-action="Index">@Localizer["Nav_Transactions"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                               asp-area="Finance" asp-controller="Category" asp-action="Index">@Localizer["Nav_Categories"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quotes" ? "active" : "")"
                               asp-area="Finance" asp-controller="Quotes" asp-action="Index">@Localizer["Nav_Quotes"]</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-2 mt-lg-0">
                        <a asp-area="Finance" asp-controller="Profile" asp-action="Index" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-2">
                            <span class="nav-avatar-btn">@(User.Identity?.Name?.Substring(0, 1).ToUpper())</span>
                            @User.Identity?.Name
                        </a>
                        <form asp-area="Finance" asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-box-arrow-right"></i> @Localizer["Nav_Exit"]
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>
    }
    else
    {
        <nav class="navbar sticky-top border-bottom" id="main-nav">
            <div class="container-lg d-flex align-items-center justify-content-between w-100">
                <a class="navbar-brand" asp-area="Finance" asp-controller="Home" asp-action="Index">
                    lawllit<span class="brand-dot">.</span><span class="brand-finance">finance</span>
                </a>
                <form asp-area="" asp-controller="Home" asp-action="SetLanguage" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)">
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="submit" name="language" value="pt-BR"
                                class="btn @(currentLanguage == "pt-BR" ? "btn-primary" : "btn-outline-secondary")">
                            PT
                        </button>
                        <button type="submit" name="language" value="en-US"
                                class="btn @(currentLanguage == "en-US" ? "btn-primary" : "btn-outline-secondary")">
                            EN
                        </button>
                    </div>
                </form>
            </div>
        </nav>
    }

    <partial name="_Notification" />

    @RenderBody()

    <footer class="site-footer">
        <div class="container-lg footer-shell">
            <span>© @DateTime.Now.Year <a class="footer-brand" asp-area="" asp-controller="Home" asp-action="Index">lawllit<span class="brand-dot">.</span></a></span>
            <div class="footer-links">
                <a href="https://github.com/paiineli" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><i class="bi bi-github"></i></a>
                <a href="https://linkedin.com/in/lucaspaineli" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/finance/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
