@{
    ViewData["Title"] = Localizer["SiteTitle"].Value;
}

<div class="landing">
    <div class="term-window" id="termWindow"
         data-line1="@Localizer["Hero_Line1"]"
         data-line2="@Localizer["Hero_Line2"]"
         data-sub="@Localizer["Hero_Sub"]"
         data-live="@Localizer["Project_LF_Live"]">
        <div class="term-titlebar">
            <div class="term-dots">
                <span class="term-dot-red"></span>
                <span class="term-dot-yellow"></span>
                <span class="term-dot-green"></span>
            </div>
            <span class="term-title">lawllit — zsh — 80×24</span>
        </div>
        <div class="term-output" id="termOutput"></div>
        <div class="term-input-line">
            <span class="term-ps1">$&nbsp;</span>
            <span id="termDisplay"></span><span class="term-cursor"></span>
        </div>
        <input id="termInput" class="term-hidden-input" type="text"
               autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
    </div>
</div>
