@{
    ViewData["Title"] = Localizer["SiteTitle"].Value;
}

<div class="landing">
    <div class="landing-inner">
        <p class="landing-brand">lawllit<span class="landing-dot">.</span></p>
        <p class="landing-tagline">@Localizer["Hero_Line1"]</p>
        <div class="landing-product-card">
            <div class="landing-product-header">
                <span class="landing-product-name">lawllit<span class="landing-accent">finance</span></span>
                <span class="landing-live">@Localizer["Project_LF_Live"]</span>
            </div>
            <p class="landing-product-desc">@Localizer["Landing_Sub"]</p>
            <a asp-area="Finance" asp-controller="Home" asp-action="Index" class="btn btn-solid">@Localizer["Project_LF_CTA"]</a>
        </div>
    </div>
</div>
