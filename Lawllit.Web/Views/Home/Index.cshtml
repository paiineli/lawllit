@{
    ViewData["Title"] = Localizer["SiteTitle"].Value;
}

<div class="landing">
    <div class="landing-shell">
        <div class="landing-left">
            <h1 class="landing-headline">
                @Localizer["Hero_Line1"]<br />
                <span class="landing-headline-dim">@Localizer["Hero_Line2"]</span>
            </h1>
            <p class="landing-sub">@Localizer["Hero_Sub"]</p>
            <div class="landing-divider"></div>
            <a asp-area="Finance" asp-controller="Home" asp-action="Index" class="landing-badge">
                <span class="landing-badge-dot"></span>
                lawllit.finance — @Localizer["Project_LF_Live"]
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="landing-right">
            <div class="terminal">
                <div class="term-bar">
                    <div class="term-dots">
                        <span></span><span></span><span></span>
                    </div>
                    <span class="term-label">lawllit cli</span>
                </div>
                <div class="term-body">
                    <p class="term-line" data-delay="0"><span class="term-prompt">$</span> lawllit run finance</p>
                    <p class="term-line term-dim" data-delay="600">&gt; @Localizer["Term_Boot"]</p>
                    <p class="term-line term-dim" data-delay="1100">&gt; @Localizer["Term_Connected"]</p>
                    <p class="term-line term-dim" data-delay="1600">&gt; @Localizer["Term_Loading"]</p>
                    <p class="term-line" data-delay="2200"><span class="term-ok">✓</span> @Localizer["Term_Ready"]</p>
                    <p class="term-line term-stat" data-delay="2450">
                        <span>@Localizer["Term_Balance"]</span><span class="term-val">R$ 2.353</span>
                    </p>
                    <p class="term-line term-stat" data-delay="2650">
                        <span>@Localizer["Term_Savings"]</span><span class="term-val term-pos">56%</span>
                    </p>
                    <p class="term-line term-stat" data-delay="2850">
                        <span>@Localizer["Term_Goals"]</span><span class="term-val">3</span>
                    </p>
                    <p class="term-line" data-delay="3200"><span class="term-prompt">$</span><span class="term-cursor"></span></p>
                </div>
            </div>
        </div>
    </div>
</div>
