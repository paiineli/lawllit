@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isPtBr = culture == "pt-BR";
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? Localizer["SiteTitle"].Value)</title>
    <meta name="description" content="@Localizer["SiteDescription"]" />
    <link rel="canonical" href="https://lawllit.com@(Context.Request.Path)" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="lawllit" />
    <meta property="og:title" content="@(ViewData["Title"] ?? Localizer["SiteTitle"].Value)" />
    <meta property="og:description" content="@Localizer["SiteDescription"]" />
    <meta property="og:url" content="https://lawllit.com@(Context.Request.Path)" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23000'/><text x='50%25' y='55%25' dominant-baseline='middle' text-anchor='middle' fill='%23fff' font-family='monospace' font-weight='bold' font-size='18'>L.</text></svg>" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top" id="main-nav">
        <div class="container-lg">
            <a class="navbar-brand brand" asp-controller="Home" asp-action="Index">lawllit<span class="brand-dot">.</span></a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navContent" aria-label="@Localizer["Nav_Menu"]">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navContent">
                <div class="navbar-nav me-auto gap-1">
                    <a class="nav-link" href="#about">@Localizer["Nav_About"]</a>
                    <a class="nav-link" href="#projects">@Localizer["Nav_Projects"]</a>
                    <a class="nav-link" href="#team">@Localizer["Nav_Team"]</a>
                    <a class="nav-link" href="#contact">@Localizer["Nav_Contact"]</a>
                </div>
                <form asp-controller="Home" asp-action="SetLanguage" method="post" class="lang mb-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                    <button type="submit" name="language" value="pt-BR" class="@(isPtBr ? "on" : "")">PT</button>
                    <span class="lang-sep">/</span>
                    <button type="submit" name="language" value="en-US" class="@(!isPtBr ? "on" : "")">EN</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container-lg footer-shell">
            <span>© @DateTime.Now.Year <span class="footer-brand">lawllit<span class="brand-dot">.</span></span></span>
            <div class="footer-links">
                <a href="https://linkedin.com/company/lawllit" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
