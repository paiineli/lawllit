<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? Localizer["SiteTitle"].Value)</title>
    <meta name="description" content="@Localizer["SiteDescription"]" />
    <link rel="canonical" href="https://lawllit.com@(Context.Request.Path)" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="lawllit" />
    <meta property="og:title" content="@(ViewData["Title"] ?? Localizer["SiteTitle"].Value)" />
    <meta property="og:description" content="@Localizer["SiteDescription"]" />
    <meta property="og:url" content="https://lawllit.com@(Context.Request.Path)" />
    <meta property="og:image" content="https://lawllit.com/og-image.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@(ViewData["Title"] ?? Localizer["SiteTitle"].Value)" />
    <meta name="twitter:description" content="@Localizer["SiteDescription"]" />
    <meta name="twitter:image" content="https://lawllit.com/og-image.png" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23000'/><text x='50%25' y='55%25' dominant-baseline='middle' text-anchor='middle' fill='%23fff' font-family='monospace' font-weight='bold' font-size='18'>L.</text></svg>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar sticky-top border-bottom" id="main-nav">
        <div class="container-lg">
            <a class="navbar-brand brand" asp-controller="Home" asp-action="Index">lawllit<span class="brand-dot">.</span></a>
        </div>
    </nav>

    @RenderBody()

    <footer class="site-footer">
        <div class="container-lg footer-shell">
            <span>© @DateTime.Now.Year <span class="footer-brand">lawllit<span class="brand-dot">.</span></span></span>
            <div class="footer-links">
                <a href="mailto:support@lawllit.com" aria-label="Email"><i class="bi bi-envelope"></i></a>
                <a href="https://www.linkedin.com/in/lucaspaineli/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
